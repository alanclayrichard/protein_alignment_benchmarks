# copy to .env and edit. .env is gitignored and auto-loaded by config.py.
# every var below is also a default in config.py — only set the ones you need to change.
# $REFS to earlier vars are expanded, and inline # comments are stripped.

# --- inputs: uniref90 (downloaded separately) + the mmseqs binary ---
# uniref90 is ~100GB; keep it on a data volume, NOT inside this repo.
UNIREF_DIR=/data/uniref90                    # base dir of the uniref90 download
UNIREF_FASTA=$UNIREF_DIR/uniref90.fasta.gz   # the fasta; build_trainset.py streams it for sequences
UNIREF_DB=$UNIREF_DIR/uniref90_db            # mmseqs createdb of uniref90; scan_leakage.py searches it
MMSEQS=mmseqs                                # mmseqs2 binary — name on $PATH, or an absolute path

# --- outputs ---
LEAKAGE_DIR=/data/uniref90/leakage           # one <bench>.txt of leaked uniref ids per benchmark (small)
TRAINSET=/data/uniref90/trainset.fasta       # the generated leakage-free training set (size depends on sampling)
# FORMATTED_DIR=./data/formatted             # where format_benchmark.py writes test fastas (default shown)

# --- scratch ---
WORK=/tmp/mmseqs_work                        # mmseqs working dir (ephemeral, safe to delete)

# --- mmseqs search + what counts as leakage ---
THREADS=8                                    # mmseqs threads — set to the cores on your box
SPLIT_MEM=16G                                # mmseqs ram budget for splitting the target db; raise on big-RAM boxes
MAXSEQS=2000                                 # max uniref hits kept per test seq (the scan warns if this caps out — then raise it)
SENS=7.5                                     # mmseqs sensitivity (higher finds more remote homologs, slower)
EVALUE=1e-3                                  # mmseqs e-value cutoff
COV=0.8                                      # min alignment coverage to call it leakage
COV_MODE=2                                   # 2 = fraction of the TEST seq covered (the leakage-faithful direction)
MIN_ID=0.2                                   # min identity to a test seq to call it leakage (>20%)

# --- training-set sampling (build_trainset.py), so you don't pull all ~121M ---
TRAIN_SAMPLE=1.0                             # keep this fraction of safe seqs (e.g. 0.05 = 5%)
TRAIN_SIZE=0                                 # cap on seqs kept, 0 = no cap (use to fix the set size)
SEED=0                                       # rng seed for the sampling

# copy to .env and edit. .env is gitignored and auto-loaded by config.py.
# every var below is also a default in config.py — only set the ones you need to change.
# $REFS to earlier vars are expanded, and inline # comments are stripped.

# --- inputs: uniref90 (downloaded separately) + the mmseqs binary ---
UNIREF_FASTA=/data/uniref90/uniref90.fasta.gz   # the fasta build_trainset.py samples from
MMSEQS=mmseqs                                    # mmseqs2 binary (use a gpu build to enable GPU=1)
GPU=                                             # set GPU=1 (+ a gpu mmseqs build) to run the leakage check on a cuda gpu

# --- outputs / scratch ---
TRAINSET=/data/uniref90/trainset.fasta          # generated leakage-free training set (fasta keyed by uniprot code)
WORK=/tmp/mmseqs_work                            # mmseqs scratch (ephemeral, safe to delete)
# FORMATTED_DIR=./data/formatted                 # where format_benchmark.py writes test fastas (default shown)

# --- leakage rule + mmseqs search ---
THREADS=8                                        # mmseqs threads
SENS=7.5                                         # mmseqs sensitivity (higher finds more remote homologs)
EVALUE=1e-3                                      # mmseqs e-value cutoff
COV=0.8                                          # min coverage to call it leakage
COV_MODE=1                                       # 1 = cover the test seq (catches a test protein contained in a longer train seq), 0 = both, 2 = train seq
MIN_ID=0.2                                       # min identity to a test seq to call it leakage (>20%)

# --- sampling ---
QUOTA=1000000                                    # how many leakage-free sequences to collect
OVERSAMPLE=1.5                                   # sample this multiple of the shortfall each round (covers dropped leakers)
MIN_LEN=20                                       # only sample proteins at least this long
MAX_LEN=1000                                     # ..and at most this long (drops fragments + giant non-physiological seqs)
SEED=0                                           # rng seed for sampling
